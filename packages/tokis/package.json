{
  "name": "@tokis/tokis",
  "version": "1.2.3",
  "description": "Tokis Only Knows Its Styles — Performance-first, token-native UI design system for React. Install this package to get all Tokis packages: @tokis/react, @tokis/theme, @tokis/core, and @tokis/tokens.",
  "main": "./index.js",
  "module": "./index.mjs",
  "types": "./index.d.ts",
  "exports": {
    ".": {
      "types": "./index.d.ts",
      "import": "./index.mjs",
      "require": "./index.js"
    }
  },
  "files": [
    "index.js",
    "index.mjs",
    "index.d.ts",
    "README.md",
    "LICENSE"
  ],
  "sideEffects": [
    "./index.js",
    "./index.mjs"
  ],
  "keywords": [
    "tokis",
    "design-system",
    "react",
    "ui",
    "components",
    "headless",
    "accessible",
    "accessibility",
    "a11y",
    "css-variables",
    "design-tokens",
    "theming",
    "dark-mode",
    "typescript",
    "ui-kit",
    "component-library",
    "react-components",
    "enterprise",
    "saas",
    "wcag",
    "aria",
    "zero-runtime",
    "token-native"
  ],
  "author": "Tokis Contributors",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/PrerakMathur20/TokisLib.git",
    "directory": "packages/tokis"
  },
  "homepage": "https://github.com/PrerakMathur20/TokisLib#readme",
  "bugs": {
    "url": "https://github.com/PrerakMathur20/TokisLib/issues"
  },
  "dependencies": {
    "@tokis/react": "^1.2.3",
    "@tokis/theme": "^1.2.3",
    "@tokis/core": "^1.2.3",
    "@tokis/tokens": "^1.2.3",
    "@tokis/icons": "^1.2.3"
  },
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "pnpm": {
    "peerDependencyRules": {
      "ignoreMissing": []
    }
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  }
}
