{
  "name": "tokis",
  "version": "1.0.9",
  "description": "Tokis Only Knows Its Styles — Performance-first, token-native UI design system for React. Install this package to get all Tokis libraries: @tokis/react, @tokis/theme, @tokis/core, and @tokis/tokens.",
  "main": "./index.js",
  "module": "./index.mjs",
  "types": "./index.d.ts",
  "exports": {
    ".": {
      "types": "./index.d.ts",
      "import": "./index.mjs",
      "require": "./index.js"
    },
    "./react": {
      "types": "@tokis/react",
      "import": "@tokis/react",
      "require": "@tokis/react"
    },
    "./theme": "@tokis/theme",
    "./core": {
      "types": "@tokis/core",
      "import": "@tokis/core",
      "require": "@tokis/core"
    },
    "./tokens": {
      "types": "@tokis/tokens",
      "import": "@tokis/tokens",
      "require": "@tokis/tokens"
    }
  },
  "files": [
    "index.js",
    "index.mjs",
    "index.d.ts",
    "README.md",
    "LICENSE"
  ],
  "sideEffects": false,
  "keywords": [
    "tokis",
    "design-system",
    "react",
    "ui",
    "components",
    "headless",
    "accessible",
    "accessibility",
    "a11y",
    "css-variables",
    "design-tokens",
    "theming",
    "dark-mode",
    "typescript",
    "ui-kit",
    "component-library",
    "react-components",
    "enterprise",
    "saas",
    "wcag",
    "aria",
    "zero-runtime",
    "token-native"
  ],
  "author": "Tokis Contributors",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/PrerakMathur20/TokisLib.git",
    "directory": "packages/tokis"
  },
  "homepage": "https://github.com/PrerakMathur20/TokisLib#readme",
  "bugs": {
    "url": "https://github.com/PrerakMathur20/TokisLib/issues"
  },
  "dependencies": {
    "@tokis/react": "^1.0.9",
    "@tokis/theme": "^1.0.9",
    "@tokis/core": "^1.0.9",
    "@tokis/tokens": "^1.0.9"
  },
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  }
}
